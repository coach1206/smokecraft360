<script>
    // --- OPTIMIZED SMOKE ENGINE FOR TOUCH ---
    const canvas = document.getElementById('smoke-canvas');
    const ctx = canvas.getContext('2d');
    let particles = [];
    const particleCount = 25; // Optimized for mobile performance

    function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    }
    window.addEventListener('resize', resize);
    resize();

    class Particle {
        constructor() {
            this.reset();
        }
        reset() {
            this.x = Math.random() * canvas.width;
            this.y = canvas.height + 100;
            this.size = Math.random() * 80 + 40;
            this.speedY = Math.random() * 0.4 + 0.15;
            this.speedX = (Math.random() - 0.5) * 0.5;
            this.opacity = 0;
            this.maxOpacity = Math.random() * 0.15 + 0.05;
            this.life = 0;
        }
        update() {
            this.y -= this.speedY;
            this.x += this.speedX;
            this.life++;
            if (this.life < 80) this.opacity += this.maxOpacity / 80;
            if (this.y < -150) this.reset();
        }
        draw() {
            ctx.beginPath();
            const gradient = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, this.size);
            gradient.addColorStop(0, `rgba(194, 101, 42, ${this.opacity})`);
            gradient.addColorStop(1, 'rgba(19, 19, 19, 0)');
            ctx.fillStyle = gradient;
            ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
            ctx.fill();
        }
    }

    for (let i = 0; i < particleCount; i++) particles.push(new Particle());

    function animate() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        particles.forEach(p => {
            p.update();
            p.draw();
        });
        requestAnimationFrame(animate);
    }
    animate();

    // --- SEQUENCE CONTROLLER ---
    window.onload = () => {
        const pLogo = document.getElementById('profound-logo');
        const nLogo = document.getElementById('novee-logo');
        const header = document.getElementById('main-header');
        const nav = document.getElementById('bottom-nav');

        setTimeout(() => {
            pLogo.classList.add('logo-slide-in');
        }, 300);

        setTimeout(() => {
            pLogo.style.opacity = '0';
            pLogo.style.transition = 'opacity 0.8s ease';
            setTimeout(() => {
                pLogo.classList.add('hidden');
                nLogo.classList.remove('hidden');
                nLogo.classList.add('power-up');
            }, 800);
        }, 2800);

        setTimeout(() => {
            goToStage('stage-portal');
            header.classList.remove('opacity-0');
            nav.classList.remove('opacity-0');
        }, 5500);
    };

    function goToStage(stageId) {
        if (window.navigator.vibrate) window.navigator.vibrate(10);

        const activeStage = document.querySelector('.stage-active');
        const targetStage = document.getElementById(stageId);

        if (!activeStage || !targetStage) return;

        activeStage.classList.remove('stage-active');
        activeStage.classList.add('stage-hidden');

        setTimeout(() => {
            targetStage.classList.remove('stage-hidden');
            targetStage.classList.add('stage-active');
            document.querySelector('main').scrollTo({ top: 0, behavior: 'smooth' });
        }, 400);
    }

    function selectMentor(el) {
        document.querySelectorAll('.glass-panel').forEach(card => {
            card.classList.remove('border-primary');
            card.classList.add('border-transparent', 'opacity-60');
            const span = card.querySelector('span:last-child');
            if (span) span.innerText = 'Select';
        });
        el.classList.add('border-primary');
        el.classList.remove('border-transparent', 'opacity-60');
        el.querySelector('span:last-child').innerText = 'Selected';
        if (window.navigator.vibrate) window.navigator.vibrate(15);
    }
</script>
